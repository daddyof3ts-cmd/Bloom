# Copy to `.env` and fill in. Used at build time (Vite); see vite.config.ts.
#
# GEMINI_API_KEY — Optional locally; required for AI features in production builds
# unless you inject `window.__RUNTIME_GEMINI_API_KEY__` on the hosted page.
GEMINI_API_KEY=

# Optional: Google Apps Script web app URL for Sheets logging (see src/lib/sheetsSync.ts)
# VITE_SHEETS_WEBHOOK_URL=
